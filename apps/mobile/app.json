{
  "expo": {
    "name": "TropTix Organizer",
    "slug": "troptix-organizer-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.troptix.organizer",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan event ticket QR codes."
      }
    },
    "android": {
      "package": "com.troptix.organizer",
      "permissions": ["android.permission.CAMERA"]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow TropTix to access your camera to scan ticket QR codes."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "scheme": "troptix-organizer",
    "experiments": {
      "typedRoutes": true
    }
  }
}
