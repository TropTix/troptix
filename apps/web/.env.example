# apps/web environment variables
#
# Copy this file to `.env` and fill in real values:
#   cp apps/web/.env.example apps/web/.env
#
# `.env` is gitignored — NEVER commit real secrets. Every value below is a
# placeholder. `NEXT_PUBLIC_*` vars are exposed to the browser; everything else
# is server-only.
#
# On Vercel, `VERCEL_ENV`, `VERCEL_URL`, `VERCEL_PROJECT_PRODUCTION_URL`, and
# `NODE_ENV` are injected automatically — you do not set them here.

# --- App URL -----------------------------------------------------------------
# Base URL used to build absolute links during local development. On Vercel the
# app derives its URL from the VERCEL_* vars instead.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ----------------------------------------------------------------
# Project URL and the publishable (anon) key from your Supabase project's API
# settings. Both are public/client-side.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# --- Postgres (Supabase / @troptix/db) ---------------------------------------
# Database connection strings consumed by the @troptix/db (Prisma) package.
# POSTGRES_PRISMA_URL is the pooled connection used at runtime;
# POSTGRES_URL_NON_POOLING is the direct connection used for migrations.
POSTGRES_PRISMA_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/postgres

# --- Stripe ------------------------------------------------------------------
# Publishable key is client-side; the secret key and the webhook signing secret
# (for the charge.succeeded webhook) are server-only.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_CHARGE_SUCCEEDED_WEBHOOK=whsec_your_webhook_signing_secret

# --- Resend (transactional email) --------------------------------------------
# API key from Resend, plus the id/handle of the dynamic email template.
RESEND_API_KEY=re_your_resend_api_key
RESEND_DYNAMIC_TEMPLATE_API=your-resend-dynamic-template-id

# --- Google Maps -------------------------------------------------------------
# Browser API key for Maps / Places features.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- PostHog (product analytics) ---------------------------------------------
# Project API key and the ingestion host (e.g. https://us.i.posthog.com).
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
